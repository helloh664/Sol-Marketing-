{
  "name": "sol-marketing-reels",
  "version": "1.0.0",
  "description": "Remotion project for vertical Instagram Reels (1080x1920 @ 30fps) with transparent compositions for compositing over footage.",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "remotion studio src/index.ts",
    "studio": "remotion studio src/index.ts",
    "build": "remotion bundle src/index.ts",
    "upgrade": "remotion upgrade",
    "lint": "tsc --noEmit",
    "render": "remotion render src/index.ts",
    "render:prores": "remotion render src/index.ts --codec=prores --prores-profile=4444 --image-format=png --pixel-format=yuva444p10le"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.0",
    "@remotion/google-fonts": "^4.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.4.0"
  }
}
